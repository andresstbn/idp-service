# ─── Proveedor LLM ───────────────────────────────────────────────
# Proveedor a usar: mock | anthropic | openai
#   mock      → sin LLM real ni API key; devuelve null por campo (Fase 1 inicial)
#   anthropic → Claude vía API (requiere ANTHROPIC_API_KEY)
#   openai    → GPT vía API (requiere OPENAI_API_KEY)
LLM_PROVIDER=mock
# Modelo. Con mock es irrelevante. Para Anthropic: claude-sonnet-4-20250514; OpenAI: gpt-4o.
LLM_MODEL=mock-model
# API key del proveedor anthropic (requerida si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# API key del proveedor openai (requerida si LLM_PROVIDER=openai)
OPENAI_API_KEY=
# Reintentos del LLM ante output que no valida contra el schema
LLM_MAX_RETRIES=2

# ─── Extracción ──────────────────────────────────────────────────
# Directorio con los JSON Schemas registrados
SCHEMAS_DIR=schemas
# Umbral objetivo (chars/página) para el fallback pymupdf → pdfplumber
PDF_MIN_CHARS_PER_PAGE=50
# Tamaño máximo de PDF aceptado (MB)
PDF_MAX_SIZE_MB=20
# Páginas máximas a enviar completas al LLM antes de truncar
PDF_MAX_PAGES_FULL=30

# ─── Servicio ────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Entorno: development | production
ENVIRONMENT=development
# Versión del servicio (aparece en /v1/health)
SERVICE_VERSION=1.0.0
